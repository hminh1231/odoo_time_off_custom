<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      Standard "Waiting For Me" ignores multi-step approvers (and own requests unless you are leave manager).
      Include leaves where the current user is in extra_approver_user_ids (multi-step, Employee HR Responsibles, etc.).
    -->
    <record id="hr_leave_view_search_waiting_for_me_multi_step" model="ir.ui.view">
        <field name="name">hr.leave.search.waiting.for.me.multi.step</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.view_hr_holidays_filter"/>
        <field name="arch" type="xml">
            <filter name="waiting_for_me" position="attributes">
                <!-- Must be able to act (approve/validate/refuse); hide requests the user cannot process -->
                <attribute name="domain">['&amp;', '&amp;', ('state','in',['confirm']), '|','|', ('employee_id.user_id', '!=', uid), '&amp;', ('employee_id.user_id', '=', uid), ('employee_id.leave_manager_id', '=', uid), ('extra_approver_user_ids', 'in', [uid]), ('approval_actionable_user_ids', 'in', [uid])]</attribute>
            </filter>
            <filter name="waiting_for_me_manager" position="attributes">
                <attribute name="domain">['&amp;', '&amp;', ('state','in',['confirm','validate1']), '|','|','|', ('employee_id.user_id', '!=', uid), '&amp;', ('state','=','confirm'), ('holiday_status_id.leave_validation_type','=','hr'), ('state','=','validate1'), ('extra_approver_user_ids', 'in', [uid]), ('approval_actionable_user_ids', 'in', [uid])]</attribute>
            </filter>
        </field>
    </record>
</odoo>
