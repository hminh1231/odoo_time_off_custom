<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_view_form_handover_recipients" model="ir.ui.view">
        <field name="name">hr.leave.form.handover.recipients</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="can_respond_handover" invisible="1"/>
                <field name="can_manage_handover_replacement" invisible="1"/>
                <button
                    name="action_handover_accept"
                    string="Accept work handover"
                    type="object"
                    class="btn-primary"
                    data-hotkey="y"
                    invisible="not can_respond_handover or not id"
                />
                <button
                    name="action_handover_refuse"
                    string="Refuse work handover"
                    type="object"
                    class="btn-secondary"
                    data-hotkey="n"
                    invisible="not can_respond_handover or not id"
                />
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_emergency_leave" invisible="1"/>
                <div
                    class="alert alert-warning"
                    role="status"
                    invisible="not is_emergency_leave"
                >
                    This request is recorded as emergency leave (insufficient advance notice).
                </div>
                <field
                    name="handover_employee_ids"
                    widget="many2many_tags"
                    options="{'no_create': True, 'no_open': True}"
                    domain="[('id', '!=', employee_id), ('user_id', '!=', False), ('id', 'not in', unavailable_handover_employee_ids)]"
                    placeholder="Select work handover recipients (max 5)"
                    readonly="state != 'confirm'"
                />
                <field name="unavailable_handover_employee_ids" invisible="1"/>
                <field
                    name="handover_waiting_label"
                    readonly="1"
                    invisible="state not in ('confirm', 'validate1') or not handover_waiting_label"
                />
                <div
                    class="alert alert-warning"
                    role="alert"
                    invisible="not can_manage_handover_replacement"
                >
                    <field name="handover_refused_label" readonly="1" nolabel="1"/>
                    <div class="mt-1">A recipient refused. Do you want to choose another colleague?</div>
                </div>
            </xpath>
            <!-- Right column (beside main fields): refusal reasons visible to anyone who can open the form -->
            <xpath expr="//div[hasclass('col_right')]" position="inside">
                <div
                    class="alert alert-light border mb-2"
                    role="status"
                    invisible="state not in ('confirm', 'validate1') or not handover_refusal_reason_label"
                >
                    <field
                        name="handover_refusal_reason_label"
                        string="Work handover refusal details"
                        readonly="1"
                        widget="text"
                    />
                </div>
            </xpath>
        </field>
    </record>

    <!-- Calendar / Time Off popup hides the form header; put handover actions in the sheet. -->
    <record id="hr_leave_view_form_dashboard_handover_actions" model="ir.ui.view">
        <field name="name">hr.leave.dashboard.form.handover.actions</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_dashboard_new_time_off"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="is_emergency_leave" invisible="1"/>
                <div
                    class="alert alert-warning mb-2"
                    role="status"
                    invisible="not is_emergency_leave"
                >
                    This request is recorded as emergency leave (insufficient advance notice).
                </div>
                <field name="can_respond_handover" invisible="1"/>
                <field name="handover_waiting_label" invisible="1"/>
                <field name="handover_refused_label" invisible="1"/>
                <field name="can_manage_handover_replacement" invisible="1"/>
                <div
                    class="alert alert-warning mb-2"
                    role="alert"
                    invisible="not id or not handover_waiting_label"
                >
                    <field name="handover_waiting_label" readonly="1" nolabel="1"/>
                </div>
                <div
                    class="alert alert-light border mb-2"
                    role="status"
                    invisible="not id or state not in ('confirm', 'validate1') or not handover_refusal_reason_label"
                >
                    <field
                        name="handover_refusal_reason_label"
                        string="Work handover refusal details"
                        readonly="1"
                        widget="text"
                    />
                </div>
                <div
                    class="alert alert-warning mb-2"
                    role="alert"
                    invisible="not id or not can_manage_handover_replacement"
                >
                    <field name="handover_refused_label" readonly="1" nolabel="1"/>
                    <div class="mt-1">A recipient refused. Do you want to choose another colleague?</div>
                </div>
                <div
                    class="alert alert-info mb-2"
                    role="alert"
                    invisible="not id or not can_respond_handover"
                >
                    <p class="mb-2">
                        You were selected for work handover for this request. Please accept or refuse.
                    </p>
                    <button
                        name="action_handover_accept"
                        string="Accept work handover"
                        type="object"
                        class="btn btn-primary me-2"
                        data-hotkey="y"
                        invisible="not can_respond_handover"
                    />
                    <button
                        name="action_handover_refuse"
                        string="Refuse work handover"
                        type="object"
                        class="btn btn-secondary"
                        data-hotkey="n"
                        invisible="not can_respond_handover"
                    />
                </div>
            </xpath>
        </field>
    </record>
</odoo>
