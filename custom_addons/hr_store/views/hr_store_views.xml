<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_store_form" model="ir.ui.view">
            <field name="name">hr.store.form</field>
            <field name="model">hr.store</field>
            <field name="arch" type="xml">
                <form string="Store">
                    <sheet>
                        <div class="oe_button_box" name="button_box" invisible="not id">
                            <button class="oe_stat_button" name="action_employee_from_store" type="object" icon="fa-users">
                                <field string="Employees" name="total_employee" widget="statinfo"/>
                            </button>
                        </div>
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                        <field name="active" invisible="1"/>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="e.g. CH Quận 1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="mien"/>
                                <field name="manager_id" widget="many2one_avatar_employee"/>
                                <field name="phone"/>
                                <field name="color" widget="color_picker"/>
                            </group>
                            <group>
                                <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                                <field name="street" placeholder="Street..."/>
                                <field name="city"/>
                                <field name="state_id"/>
                                <field name="country_id"/>
                            </group>
                        </group>
                        <group string="Note">
                            <field name="note" nolabel="1" placeholder="Internal notes about this store..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_store_tree" model="ir.ui.view">
            <field name="name">hr.store.list</field>
            <field name="model">hr.store</field>
            <field name="arch" type="xml">
                <list string="Stores" multi_edit="1">
                    <field name="active" column_invisible="True"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="mien"/>
                    <field name="manager_id" widget="many2one_avatar_employee"/>
                    <field name="city"/>
                    <field name="total_employee" string="Employees"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="color" widget="color_picker" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_hr_store_kanban" model="ir.ui.view">
            <field name="name">hr.store.kanban</field>
            <field name="model">hr.store</field>
            <field name="arch" type="xml">
                <kanban highlight_color="color" class="o_kanban_small_column" sample="1">
                    <field name="active"/>
                    <templates>
                        <t t-name="card">
                            <a type="open"><field name="name" class="fw-bold fs-4 d-block ms-2"/></a>
                            <div class="text-muted ms-2" t-if="record.code.raw_value">
                                <i class="fa fa-barcode" title="Code"/> <field name="code"/>
                            </div>
                            <field name="manager_id" widget="many2one_avatar_employee" options="{'display_avatar_name': True}" readonly="1" class="text-muted ms-2"/>
                            <div class="small mt-1 ms-2" groups="base.group_multi_company">
                                <i class="fa fa-building-o" title="Company"/> <field name="company_id"/>
                            </div>
                            <div class="row g-0 mt-3 mb-2 ms-2" t-if="!selection_mode">
                                <div class="col-6">
                                    <button class="btn btn-primary" name="action_employee_from_store" type="object">
                                        <field name="total_employee"/> Employees
                                    </button>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_hr_store_search" model="ir.ui.view">
            <field name="name">hr.store.search</field>
            <field name="model">hr.store</field>
            <field name="arch" type="xml">
                <search string="Stores">
                    <field name="name" string="Store"/>
                    <field name="code"/>
                    <field name="mien"/>
                    <field name="manager_id"/>
                    <field name="city"/>
                    <separator/>
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    <group>
                        <filter string="Miền" name="group_mien" context="{'group_by': 'mien'}"/>
                        <filter string="Manager" name="group_manager" context="{'group_by': 'manager_id'}"/>
                        <filter string="City" name="group_city" context="{'group_by': 'city'}"/>
                        <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="hr_store_action" model="ir.actions.act_window">
            <field name="name">Cửa hàng</field>
            <field name="res_model">hr.store</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="search_view_id" ref="view_hr_store_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new store
                </p>
                <p>
                    Manage retail stores and assign employees to each location.
                </p>
            </field>
        </record>
    </data>
</odoo>
