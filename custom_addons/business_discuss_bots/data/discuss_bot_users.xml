<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="partner_bot_handover" model="res.partner">
            <field name="name">OdooBot Bàn giao việc</field>
            <field name="email">odoo.bot.handover@example.com</field>
            <field name="company_type">person</field>
            <field name="image_1920" type="base64" file="business_discuss_bots/static/src/img/bot_handover.png"/>
        </record>

        <record id="partner_bot_approval" model="res.partner">
            <field name="name">OdooBot Duyệt đơn</field>
            <field name="email">odoo.bot.approval@example.com</field>
            <field name="company_type">person</field>
            <field name="image_1920" type="base64" file="business_discuss_bots/static/src/img/bot_approval.png"/>
        </record>
        <record id="partner_bot_gate_ticket" model="res.partner">
            <field name="name">OdooBot Ra cổng</field>
            <field name="email">odoo.bot.gate.ticket@example.com</field>
            <field name="company_type">person</field>
            <field name="image_1920" type="base64" file="business_discuss_bots/static/src/img/bot_gate_ticket.png"/>
        </record>

        <record id="user_bot_handover" model="res.users">
            <field name="name">OdooBot Bàn giao việc</field>
            <field name="login">odoo.bot.handover</field>
            <field name="partner_id" ref="business_discuss_bots.partner_bot_handover"/>
            <field name="group_ids" eval="[Command.set([ref('base.group_user')])]"/>
        </record>

        <record id="user_bot_approval" model="res.users">
            <field name="name">OdooBot Duyệt đơn</field>
            <field name="login">odoo.bot.approval</field>
            <field name="partner_id" ref="business_discuss_bots.partner_bot_approval"/>
            <field name="group_ids" eval="[Command.set([ref('base.group_user')])]"/>
        </record>
        <record id="user_bot_gate_ticket" model="res.users">
            <field name="name">OdooBot Ra cổng</field>
            <field name="login">odoo.bot.gate.ticket</field>
            <field name="partner_id" ref="business_discuss_bots.partner_bot_gate_ticket"/>
            <field name="group_ids" eval="[Command.set([ref('base.group_user')])]"/>
        </record>
    </data>
</odoo>
