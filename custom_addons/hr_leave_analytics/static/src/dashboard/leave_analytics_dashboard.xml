<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hr_leave_analytics.LeaveAnalyticsDashboard">
        <div class="o_leave_analytics_dashboard o_action o_action_delegate_scroll">
            <div class="o_leave_analytics_header mb-2">
                <div class="o_dashboard_title_row">
                    <h1 class="o_dashboard_main_title" t-esc="dashboardTitle"/>
                    <h2 class="o_dashboard_sub_title" t-esc="reportSubtitle"/>
                </div>
                <p class="text-muted mb-0 o_dashboard_period_note"><t t-esc="periodLabel"/> — Sáng Tâm</p>
            </div>

            <t t-if="state.loading">
                <div class="text-center p-5"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            </t>

            <t t-elif="state.data">
                <!-- 1. Bộ lọc -->
                <div class="o_filter_bar mb-3">
                    <div class="o_filter_item">
                        <label class="o_filter_label">Năm</label>
                        <select class="form-select form-select-sm o_filter_select" t-model.number="state.filterYear" t-on-change="onFilterChange">
                            <t t-foreach="filterOptions.years || []" t-as="year" t-key="year">
                                <option t-att-value="year" t-esc="year"/>
                            </t>
                        </select>
                    </div>
                    <div class="o_filter_item">
                        <label class="o_filter_label">Tháng</label>
                        <select class="form-select form-select-sm o_filter_select" t-model.number="state.filterMonth" t-on-change="onFilterChange">
                            <t t-foreach="filterOptions.months || []" t-as="month" t-key="month.value">
                                <option t-att-value="month.value" t-esc="month.label"/>
                            </t>
                        </select>
                    </div>
                    <div class="o_filter_item o_filter_item_wide">
                        <label class="o_filter_label">Mã bộ phận</label>
                        <select class="form-select form-select-sm o_filter_select o_filter_select_wide" t-model.number="state.filterMaBoPhanId" t-on-change="onFilterChange">
                            <option value="">Tất cả</option>
                            <t t-foreach="filterOptions.ma_bo_phans || []" t-as="code" t-key="code.id">
                                <option t-att-value="code.id" t-esc="code.name"/>
                            </t>
                        </select>
                    </div>
                    <div class="o_filter_actions">
                        <button type="button" class="btn btn-sm btn-light o_filter_reset" t-on-click="resetFilters" title="Đặt lại bộ lọc">
                            <i class="fa fa-refresh"/>
                        </button>
                    </div>
                </div>

                <!-- 2. KPI 6 ô -->
                <div class="row g-2 mb-3 o_kpi_row">
                    <t t-foreach="kpiCards" t-as="card" t-key="card.key">
                        <div class="col-6 col-lg-2">
                            <div t-att-class="kpiCardClass(card) + (card.drill ? ' o_kpi_clickable' : '')"
                                 t-on-click="() => this.onKpiClick(card.drill)">
                                <div class="o_kpi_label" t-esc="card.label"/>
                                <div class="o_kpi_value">
                                    <t t-esc="card.value"/><t t-if="card.suffix" t-esc="card.suffix"/>
                                </div>
                                <div t-if="card.drill" class="o_kpi_hint">
                                    Bấm để xem chi tiết bên dưới
                                </div>
                                <button t-if="card.drill"
                                        type="button"
                                        class="btn btn-link btn-sm o_kpi_list_btn p-0"
                                        t-on-click.stop="() => this.openDrill(card.drill)">
                                    Xem danh sách đơn →
                                </button>
                            </div>
                        </div>
                    </t>
                </div>

                <!-- Panel chi tiết KPI -->
                <t t-if="state.activeKpiDrill">
                    <div class="card mb-3 o_kpi_drill_panel" t-ref="kpiDrillPanel">
                        <div class="card-header o_kpi_drill_header d-flex justify-content-between align-items-center">
                            <span><i class="fa fa-list-alt me-2"/><t t-esc="state.kpiDrillTitle"/></span>
                            <div>
                                <button class="btn btn-sm btn-primary me-1" t-on-click="() => this.openDrill(state.activeKpiDrill)">
                                    <i class="fa fa-external-link me-1"/>Mở danh sách đơn
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" t-on-click="closeKpiDrill">
                                    <i class="fa fa-times"/>
                                </button>
                            </div>
                        </div>
                        <div class="card-body p-0 o_kpi_drill_body">
                            <t t-if="state.kpiDrillRows.length">
                                <table class="table table-sm mb-0 o_grid_table o_kpi_drill_table">
                                    <thead>
                                        <tr>
                                            <th>Nhân viên</th>
                                            <th t-esc="locationColumnLabel"/>
                                            <th>Loại nghỉ</th>
                                            <th>Từ ngày</th>
                                            <th>Đến ngày</th>
                                            <th>Số ngày</th>
                                            <th>Trạng thái</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.kpiDrillRows" t-as="row" t-key="row.leave_id">
                                            <tr class="cursor-pointer" t-on-click="() => this.openLeave(row.leave_id)">
                                                <td t-esc="row.employee_name"/>
                                                <td t-esc="row.store_name"/>
                                                <td t-esc="row.leave_type"/>
                                                <td class="o_td_center" t-esc="row.request_date_from"/>
                                                <td class="o_td_center" t-esc="row.request_date_to"/>
                                                <td class="o_td_number" t-esc="row.number_of_days"/>
                                                <td class="o_td_center">
                                                    <span t-att-class="statusBadgeClass(row)" t-esc="row.status_label"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                            <t t-else="">
                                <div class="text-muted text-center py-3 o_empty_row">Không có dữ liệu</div>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- 3. Doughnut + Bar miền -->
                <div class="row g-2 mb-3">
                    <div class="col-lg-5">
                        <div class="card h-100 o_panel_card">
                            <div class="card-header o_header_status">Trạng thái đơn nghỉ</div>
                            <div class="card-body o_chart_card_body o_chart_donut_body">
                                <div class="o_chart_canvas_wrap o_chart_donut">
                                    <canvas t-ref="statusDonutChart"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-7">
                        <div class="card h-100 o_panel_card">
                            <div class="card-header o_header_mien d-flex justify-content-between">
                                <span>Ngày nghỉ theo miền (đã duyệt)</span>
                                <button class="btn btn-sm btn-outline-light py-0 px-2" t-on-click="() => this.openList('mien_compare')">
                                    <i class="fa fa-table"/>
                                </button>
                            </div>
                            <div class="card-body o_chart_card_body o_chart_bar_body">
                                <div class="o_chart_canvas_wrap o_chart_bar o_chart_bar_mien">
                                    <canvas t-ref="mienBarChart"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 4. Xu hướng 12 tháng + Top cửa hàng -->
                <div class="row g-2 mb-3">
                    <div class="col-lg-7">
                        <div class="card h-100 o_panel_card">
                            <div class="card-header o_header_trend">Xu hướng nghỉ 12 tháng</div>
                            <div class="card-body o_chart_card_body">
                                <div class="o_chart_canvas_wrap o_chart_line">
                                    <canvas t-ref="trendLineChart"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-5">
                        <div class="card h-100 o_panel_card">
                            <div class="card-header o_header_store d-flex justify-content-between">
                                <span t-esc="topLocationTitle"/>
                                <button class="btn btn-sm btn-outline-light py-0 px-2" t-on-click="() => this.openList('top_stores')">
                                    <i class="fa fa-file-excel-o"/>
                                </button>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0 o_compact_table o_grid_table">
                                    <thead>
                                        <tr>
                                            <th t-esc="locationColumnLabel"/>
                                            <th>Tỷ lệ (%)</th>
                                            <th>NV nghỉ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="topStores" t-as="row" t-key="row.store_id">
                                            <tr class="cursor-pointer" t-on-click="() => this.drillDown('store', row.store_id)">
                                                <td t-esc="row.store_name"/>
                                                <td class="o_td_number">
                                                    <span t-att-class="rateTierClass(row.leave_rate)" class="fw-bold">
                                                        <t t-esc="row.leave_rate"/>%
                                                    </span>
                                                </td>
                                                <td class="o_td_number" t-esc="row.on_leave_count"/>
                                            </tr>
                                        </t>
                                        <tr t-if="!topStores.length">
                                            <td colspan="3" class="text-muted text-center o_empty_row">Chưa có dữ liệu</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 5. Kanban: nghỉ hôm nay / chờ duyệt / chờ bàn giao -->
                <div class="o_workflow_kanban mb-3">
                    <div class="row g-3">
                        <t t-foreach="workflowKanbanColumns" t-as="col" t-key="col.key">
                            <div class="col-lg-4 d-flex">
                                <div class="o_kanban_column flex-grow-1">
                                    <div t-att-class="'o_kanban_column_header ' + col.headerClass">
                                        <div class="o_kanban_header_main">
                                            <span class="o_kanban_column_title" t-esc="col.title"/>
                                            <span class="o_kanban_column_count" t-esc="col.rows.length"/>
                                        </div>
                                        <button type="button"
                                                class="btn btn-sm o_kanban_view_all"
                                                t-on-click="() => this.openDrill(col.drill)">
                                            Xem tất cả
                                        </button>
                                    </div>
                                    <div class="o_kanban_column_body p-0">
                                        <table class="table table-sm mb-0 o_kanban_table">
                                            <thead>
                                                <tr>
                                                    <th>Tên NV</th>
                                                    <th t-esc="locationColumnLabel"/>
                                                    <th>Chức danh</th>
                                                    <th>Số ngày nghỉ</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="col.rows" t-as="row" t-key="row.leave_id">
                                                    <tr class="cursor-pointer" t-on-click="() => this.openLeave(row.leave_id)">
                                                        <td t-esc="row.employee_name"/>
                                                        <td t-esc="row.store_name"/>
                                                        <td t-esc="row.job_title"/>
                                                        <td t-esc="row.number_of_days"/>
                                                    </tr>
                                                </t>
                                                <tr t-if="!col.rows.length">
                                                    <td colspan="4" class="o_kanban_empty_cell" t-esc="col.emptyText"/>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- 6. Cảnh báo nhân sự -->
                <div class="card mb-3 o_panel_card">
                    <div class="card-header o_header_alert">
                        <i class="fa fa-exclamation-triangle me-2"/>Cảnh báo nhân sự
                    </div>
                    <div class="card-body p-0 o_staff_alerts_body">
                        <table class="table table-sm mb-0 o_grid_table o_staff_alerts_table">
                            <thead>
                                <tr>
                                    <th>STT</th>
                                    <th>Mã bộ phận</th>
                                    <th>Loại</th>
                                    <th>Chi tiết</th>
                                    <th>Tỷ lệ</th>
                                    <th>Mức độ</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="staffAlerts" t-as="alert" t-key="alert_index">
                                    <tr t-att-class="alertRowClass(alert)">
                                        <td class="o_td_number" t-esc="alert.stt"/>
                                        <td class="o_td_center fw-semibold" t-esc="alert.code"/>
                                        <td class="o_td_center" t-esc="alert.type_label"/>
                                        <td t-esc="alert.detail"/>
                                        <td class="o_td_number fw-bold" t-esc="alert.rate_display"/>
                                        <td class="o_td_center">
                                            <span t-att-class="alertLevelBadgeClass(alert)" t-esc="alert.level_label"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr t-if="!staffAlerts.length">
                                    <td colspan="6" class="o_staff_alert_empty">
                                        <i class="fa fa-check-circle me-2"/>Không có cảnh báo nhân sự
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Chi tiết đơn (thu gọn) -->
                <div class="card o_panel_card o_detail_card">
                    <div class="card-header o_header_detail d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <span>Chi tiết đơn nghỉ trong kỳ</span>
                        <div class="d-flex align-items-end gap-2 o_detail_filter_bar">
                            <div class="o_filter_item o_filter_item_inline">
                                <label class="o_filter_label">Mã bộ phận</label>
                                <select class="form-select form-select-sm o_filter_select o_filter_select_wide"
                                        t-model.number="state.detailDraftMaBoPhanId">
                                    <option value="">Tất cả</option>
                                    <t t-foreach="filterOptions.ma_bo_phans || []" t-as="code" t-key="'detail_' + code.id">
                                        <option t-att-value="code.id" t-esc="code.name"/>
                                    </t>
                                </select>
                            </div>
                            <div class="o_filter_item o_filter_item_inline">
                                <label class="o_filter_label">Trạng thái</label>
                                <select class="form-select form-select-sm o_filter_select o_filter_select_wide"
                                        t-model="state.detailDraftLeaveStatus">
                                    <option value="">Tất cả</option>
                                    <t t-foreach="filterOptions.leave_statuses || []" t-as="status" t-key="'detail_status_' + status.value">
                                        <option t-att-value="status.value" t-esc="status.label"/>
                                    </t>
                                </select>
                            </div>
                            <button type="button"
                                    class="btn btn-sm btn-light py-0 px-2 align-self-end o_detail_search_btn"
                                    t-on-click="onDetailSearch"
                                    t-att-disabled="state.detailLoading">
                                <i t-if="state.detailLoading" class="fa fa-spinner fa-spin me-1"/>
                                <i t-else="" class="fa fa-search me-1"/>
                                Tìm kiếm
                            </button>
                            <button class="btn btn-sm btn-outline-light py-0 px-2 align-self-end" t-on-click="() => this.openList('leave_details')">
                                <i class="fa fa-file-excel-o me-1"/>Xuất Excel
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0 o_detail_table_wrap">
                        <table class="table table-sm mb-0 o_detail_table o_grid_table">
                            <thead>
                                <tr>
                                    <th>STT</th><th>Miền</th><th>Họ tên</th><th t-esc="locationColumnLabel"/>
                                    <th>Loại nghỉ</th><th>Từ</th><th>Đến</th><th>Ngày</th><th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="leaveDetails" t-as="row" t-key="row.leave_id">
                                    <tr class="cursor-pointer" t-on-click="() => this.openLeave(row.leave_id)">
                                        <td class="o_td_number" t-esc="row.stt"/>
                                        <td class="o_td_center" t-esc="row.employee_mien"/>
                                        <td t-esc="row.employee_name"/>
                                        <td t-esc="row.ma_bo_phan"/>
                                        <td t-esc="row.leave_type"/>
                                        <td class="o_td_center" t-esc="row.request_date_from"/>
                                        <td class="o_td_center" t-esc="row.request_date_to"/>
                                        <td class="o_td_number" t-esc="row.number_of_days"/>
                                        <td class="o_td_center">
                                            <span t-att-class="statusBadgeClass(row)" t-esc="row.status_label"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr t-if="!leaveDetails.length">
                                    <td colspan="9" class="text-muted text-center o_empty_row">Chưa có đơn trong kỳ</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
