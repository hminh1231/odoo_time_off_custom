<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_rule_hr_version_own_employee_read" model="ir.rule">
        <field name="name">Employee Contract: own employee read (time off)</field>
        <field name="model_id" ref="hr.model_hr_version"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <data noupdate="1">
        <record id="hr_version_officer_mien_rule" model="ir.rule">
            <field name="name">Employee Contract: Officer filtered by workforce visibility</field>
            <field name="model_id" ref="hr.model_hr_version"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
