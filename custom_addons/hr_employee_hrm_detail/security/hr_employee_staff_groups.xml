<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Legacy staff groups; visibility checkboxes live in hr_employee_visibility_groups.xml -->
    <record id="group_hr_employees_staff" model="res.groups">
        <field name="name">Employee</field>
        <field name="sequence">12</field>
        <field name="privilege_id" ref="hr.res_groups_privilege_employees"/>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        <field name="comment">Standard employee. Assign EMP_OFFICE or EMP_STORE per user.</field>
    </record>

    <record id="group_hr_employees_supporter" model="res.groups">
        <field name="name">Support Staff</field>
        <field name="sequence">11</field>
        <field name="privilege_id" ref="hr.res_groups_privilege_employees"/>
        <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="comment">HR officer (tạo/sửa NV). Phạm vi xem: tick EMP_ALL / EMP_STORE / EMP_OFFICE riêng.</field>
    </record>
</odoo>
