<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_vn_language_switch" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.vn.language.switch</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Localization" string="Localization" name="vn_language_switch" groups="base.group_system">
                    <block title="Language" name="vn_language_block">
                        <setting id="vn_language_switch_setting" string="Enable user language switch">
                            <field name="enable_user_language_switch" widget="boolean_toggle"/>
                            <div class="text-muted">
                                When enabled, each user can switch English/Vietnamese from the top-right user menu.
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
