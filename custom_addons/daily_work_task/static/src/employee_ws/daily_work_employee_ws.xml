<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="daily_work_task.DailyWorkEmployeeWs">
        <div class="o_daily_work_employee_ws o_action">
            <div class="o_content o_ews_scroll">
                <div class="o_ews_header">
                    <h2>
                        <i class="fa fa-user"/> Không Gian Làm Việc Của Nhân Viên
                    </h2>
                    <div class="o_ews_filters">
                        <div class="o_ews_filter_item">
                            <label>Từ ngày</label>
                            <input type="date" class="form-control form-control-sm"
                                   t-model="state.dateFrom"/>
                        </div>
                        <div class="o_ews_filter_item">
                            <label>Đến ngày</label>
                            <input type="date" class="form-control form-control-sm"
                                   t-model="state.dateTo"/>
                        </div>
                        <button type="button" class="btn btn-success btn-sm" t-on-click="onFilter">
                            <i class="fa fa-search"/> Xem việc của tôi
                        </button>
                    </div>
                </div>

                <t t-if="state.loading">
                    <div class="text-center p-5">
                        <i class="fa fa-spinner fa-spin fa-2x"/>
                    </div>
                </t>
                <t t-elif="state.message">
                    <div class="alert alert-warning m-3" t-esc="state.message"/>
                </t>
                <t t-else="">
                    <div class="o_ews_info" t-if="state.employee">
                        Xin chào <strong t-esc="state.employee.name"/>
                        <t t-if="state.employee.department">
                            — <span t-esc="state.employee.department"/>
                        </t>
                        · <span t-esc="state.tasks.length"/> công việc
                    </div>

                    <div class="o_ews_layout" t-ref="layout" t-att-style="layoutStyle"
                         t-att-class="{'o_ews_layout_resizing': state.resizing}">
                        <aside class="o_ews_form_panel" t-att-class="{'o_ews_form_editing': state.editingTaskId}">
                            <h3 class="o_ews_form_title">
                                <t t-if="state.editingTaskId">
                                    <i class="fa fa-pencil"/> Chỉnh sửa công việc
                                </t>
                                <t t-else="">
                                    <i class="fa fa-plus-circle"/> Thêm công việc của tôi
                                </t>
                            </h3>
                            <form t-on-submit="onSubmit">
                                <div class="o_ews_field">
                                    <label>Tên công việc <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control"
                                           placeholder="Nhập tên nhiệm vụ..."
                                           t-model="state.form.name" required="required"/>
                                </div>
                                <div class="o_ews_field">
                                    <label>Hạn hoàn thành <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control"
                                           t-model="state.form.deadline" required="required"/>
                                </div>
                                <div class="o_ews_field">
                                    <label>Ngày giao việc</label>
                                    <input type="date" class="form-control"
                                           t-model="state.form.assign_date"/>
                                    <small class="text-muted">Mặc định = hôm nay</small>
                                </div>
                                <div class="o_ews_field">
                                    <label>Hạng mục</label>
                                    <select class="form-select" t-model="state.form.work_group_id">
                                        <option value="">-- Chọn hạng mục --</option>
                                        <t t-foreach="state.workGroups" t-as="g" t-key="g.id">
                                            <option t-att-value="g.id" t-esc="g.name"/>
                                        </t>
                                    </select>
                                    <small class="text-muted" t-if="!state.workGroups.length">
                                        Chưa có hạng mục cho phòng ban của bạn. Liên hệ quản trị (Cấu hình → Hạng mục).
                                    </small>
                                </div>
                                <div class="o_ews_field">
                                    <label>Người phụ trách</label>
                                    <input type="text" class="form-control" readonly="readonly"
                                           t-att-value="state.employee.name"/>
                                </div>
                                <div class="o_ews_field">
                                    <label>Thời gian thực hiện (phút)</label>
                                    <input type="number" class="form-control" min="0" step="1"
                                           placeholder="Vd: 60"
                                           t-model="state.form.duration_minutes"/>
                                    <small class="text-muted">
                                        Tổng thời gian thực hiện: <strong t-esc="formHoursPreview()"/>
                                    </small>
                                </div>
                                <div class="o_ews_field" t-if="state.editingTaskId">
                                    <label>% hoàn thành CV</label>
                                    <input type="number" class="form-control" min="0" max="100" step="1"
                                           t-model="state.form.completion_percent"/>
                                </div>
                                <div class="o_ews_field">
                                    <label>Mức độ ưu tiên</label>
                                    <select class="form-select" t-model="state.form.priority">
                                        <t t-foreach="state.priorities" t-as="p" t-key="p.value">
                                            <option t-att-value="p.value" t-esc="p.label"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="o_ews_field">
                                    <label>Trạng thái hiện tại</label>
                                    <select class="form-select" t-model="state.form.state">
                                        <t t-foreach="state.states" t-as="s" t-key="s.value">
                                            <option t-att-value="s.value" t-esc="s.label"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="o_ews_field">
                                    <label>Ghi chú</label>
                                    <textarea class="form-control" rows="3"
                                              placeholder="Nhập mô tả chi tiết..."
                                              t-model="state.form.note"/>
                                </div>
                                <div class="o_ews_form_actions">
                                    <button type="submit" class="btn o_ews_submit"
                                            t-att-disabled="state.saving">
                                        <t t-if="state.editingTaskId">
                                            <i class="fa fa-save"/>
                                            <t t-if="state.saving"> Đang lưu...</t>
                                            <t t-else=""> Lưu thay đổi</t>
                                        </t>
                                        <t t-else="">
                                            <i class="fa fa-save"/>
                                            <t t-if="state.saving"> Đang lưu...</t>
                                            <t t-else=""> Lưu công việc của tôi</t>
                                        </t>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary o_ews_cancel"
                                            t-if="state.editingTaskId"
                                            t-att-disabled="state.saving"
                                            t-on-click="onCancelEdit">
                                        <i class="fa fa-times"/> Hủy
                                    </button>
                                </div>
                            </form>
                        </aside>

                        <div class="o_ews_splitter" t-if="state.showMyList"
                             title="Kéo để chỉnh độ rộng (double-click để về mặc định)"
                             t-on-pointerdown="onSplitterPointerDown"
                             t-on-dblclick="onSplitterDblClick">
                            <span class="o_ews_splitter_grip"/>
                        </div>

                        <section class="o_ews_table_panel" t-if="state.showMyList">
                            <h3 class="o_ews_table_title">
                                Danh sách việc của tôi
                                <span class="o_ews_total_hours" t-if="state.tasks.length">
                                    · Tổng TG: <strong t-esc="formatHours(state.totalDurationMinutes)"/> giờ
                                    (<t t-esc="state.totalDurationMinutes"/> phút)
                                    · % Hoàn thành CV: <strong t-esc="formatAvgCompletion()"/>%
                                </span>
                                <button type="button" class="btn btn-link btn-sm o_ews_toggle_list"
                                        t-on-click="toggleMyList">
                                    <i class="fa fa-compress"/> Thu gọn
                                </button>
                            </h3>
                            <div class="o_ews_table_wrap">
                                <table class="o_ews_table">
                                    <thead>
                                        <tr>
                                            <th class="o_ews_col_stt">STT</th>
                                            <th>Tên công việc</th>
                                            <th>Ngày giao việc</th>
                                            <th>Hạn hoàn thành</th>
                                            <th>Mức ưu tiên</th>
                                            <th>Thời gian (phút)</th>
                                            <th>Tổng TG (giờ)</th>
                                            <th>% hoàn thành CV</th>
                                            <th>Trạng thái công việc</th>
                                            <th>Ghi chú</th>
                                            <th class="o_ews_col_action">Thao tác</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-if="!state.tasks.length">
                                            <tr>
                                                <td colspan="11" class="text-center text-muted py-4">
                                                    Chưa có công việc. Hãy thêm việc mới ở form bên trái.
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-foreach="state.tasks" t-as="task" t-key="task.id">
                                            <tr t-att-class="{'o_ews_row_editing': state.editingTaskId === task.id}">
                                                <td class="o_ews_col_stt" t-esc="task.stt"/>
                                                <td t-esc="task.name"/>
                                                <td t-esc="task.assign_date_display || '—'"/>
                                                <td t-esc="task.deadline_display"/>
                                                <td>
                                                    <span t-att-class="'o_ews_badge ' + priorityClass(task.priority)"
                                                          t-esc="task.priority_label"/>
                                                </td>
                                                <td>
                                                    <input type="number" class="form-control form-control-sm o_ews_minutes_input"
                                                           min="0" step="1"
                                                           t-att-value="task.duration_minutes || 0"
                                                           t-on-change="(ev) => this.onDurationChange(task, ev)"/>
                                                </td>
                                                <td class="o_ews_hours_cell"
                                                    t-esc="task.duration_hours_display || formatHours(task.duration_minutes)"/>
                                                <td class="o_ews_pct_cell">
                                                    <div class="o_ews_pct_wrap">
                                                        <input type="number"
                                                               class="form-control form-control-sm o_ews_pct_input"
                                                               min="0" max="100" step="1"
                                                               t-att-value="task.completion_percent || 0"
                                                               t-on-change="(ev) => this.onCompletionChange(task, ev)"/>
                                                        <span class="o_ews_pct_suffix">%</span>
                                                    </div>
                                                    <div class="o_ews_pct_bar">
                                                        <div class="o_ews_pct_fill"
                                                             t-att-style="'width:' + (task.completion_percent || 0) + '%'"/>
                                                    </div>
                                                </td>
                                                <td>
                                                    <select t-att-class="'form-select form-select-sm o_ews_state_select ' + stateSelectClass(task.state)"
                                                            t-att-value="task.state"
                                                            t-on-change="(ev) => this.onStateChange(task, ev)">
                                                        <t t-foreach="state.states" t-as="s" t-key="s.value">
                                                            <option t-att-value="s.value"
                                                                    t-att-selected="s.value === task.state"
                                                                    t-esc="s.label"/>
                                                        </t>
                                                    </select>
                                                </td>
                                                <td t-esc="task.note"/>
                                                <td class="o_ews_col_action">
                                                    <button type="button"
                                                            class="btn btn-sm o_ews_btn_edit"
                                                            t-att-title="'Chỉnh sửa: ' + (task.name || '')"
                                                            t-on-click="() => this.onEditTask(task)">
                                                        <i class="fa fa-pencil"/> Chỉnh sửa
                                                    </button>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                    </div>

                    <div class="o_ews_list_toggle_bar" t-if="!state.showMyList">
                        <button type="button" class="btn btn-outline-primary btn-sm"
                                t-on-click="toggleMyList">
                            <i class="fa fa-list"/> Hiện danh sách việc của tôi
                            <t t-if="state.tasks.length">
                                (<t t-esc="state.tasks.length"/> việc đang mở)
                            </t>
                        </button>
                        <span class="text-muted">
                            Đã ẩn danh sách để bảng tháng rộng hơn. Thêm/sửa việc dùng form bên trái.
                        </span>
                    </div>

                    <!-- Tổng công việc trong tháng — phía dưới (nhóm theo hạng mục) -->
                    <section class="o_ews_month_panel">
                        <div class="o_ews_month_header">
                            <h3 class="o_ews_month_title">
                                <i class="fa fa-table"/> <t t-esc="monthTitle"/>
                            </h3>
                            <div class="o_ews_month_banner_wrap">
                                <div class="o_ews_month_banner_row">
                                    <img class="o_ews_sataco_logo"
                                         t-att-src="satacoLogoUrl"
                                         alt="SATACO — Sáng Tâm Co.Ltd"/>
                                    <div class="o_ews_month_banner" role="heading" aria-level="2">
                                        BÁO CÁO CÔNG VIỆC
                                    </div>
                                </div>
                                <div class="o_ews_month_employee" t-if="state.employee">
                                    <span class="o_ews_month_employee_name"
                                          t-esc="state.employee.name"/>
                                    <t t-if="state.employee.department">
                                        <span class="o_ews_month_employee_dept"
                                              t-esc="'— ' + state.employee.department"/>
                                    </t>
                                </div>
                            </div>
                            <div class="o_ews_month_filters">
                                <div class="o_ews_filter_item">
                                    <label>Tháng</label>
                                    <select class="form-select form-select-sm" t-model="state.monthMonth">
                                        <t t-foreach="state.months" t-as="m" t-key="m.value">
                                            <option t-att-value="m.value" t-esc="m.label"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="o_ews_filter_item">
                                    <label>Năm</label>
                                    <select class="form-select form-select-sm" t-model="state.monthYear">
                                        <t t-foreach="state.years" t-as="y" t-key="y">
                                            <option t-att-value="y" t-esc="y"/>
                                        </t>
                                    </select>
                                </div>
                                <button type="button" class="btn btn-outline-success btn-sm"
                                        t-on-click="onMonthFilter"
                                        t-att-disabled="state.monthLoading">
                                    <i class="fa fa-refresh"/> Xem tháng
                                </button>
                                <button type="button" class="btn btn-success btn-sm"
                                        t-on-click="onExportExcel"
                                        t-att-disabled="state.exporting || state.monthLoading">
                                    <i class="fa fa-file-excel-o"/>
                                    <t t-if="state.exporting"> Đang xuất...</t>
                                    <t t-else=""> Xuất Excel</t>
                                </button>
                            </div>
                        </div>

                        <t t-if="state.monthLoading">
                            <div class="text-center py-4">
                                <i class="fa fa-spinner fa-spin"/>
                            </div>
                        </t>
                        <t t-elif="state.monthMessage">
                            <div class="alert alert-warning mb-0" t-esc="state.monthMessage"/>
                        </t>
                        <t t-else="">
                            <div class="o_ews_month_kpi">
                                <div class="o_ews_kpi_card">
                                    <span class="o_ews_kpi_label">Tổng số</span>
                                    <span class="o_ews_kpi_value" t-esc="state.monthKpi.total"/>
                                </div>
                                <div class="o_ews_kpi_card o_ews_kpi_done">
                                    <span class="o_ews_kpi_label">Hoàn thành</span>
                                    <span class="o_ews_kpi_value" t-esc="state.monthKpi.done"/>
                                </div>
                                <div class="o_ews_kpi_card o_ews_kpi_progress">
                                    <span class="o_ews_kpi_label">Đang xử lý</span>
                                    <span class="o_ews_kpi_value" t-esc="state.monthKpi.in_progress"/>
                                </div>
                                <div class="o_ews_kpi_card o_ews_kpi_todo">
                                    <span class="o_ews_kpi_label">Chưa bắt đầu</span>
                                    <span class="o_ews_kpi_value" t-esc="state.monthKpi.not_started"/>
                                </div>
                                <div class="o_ews_kpi_card o_ews_kpi_overdue">
                                    <span class="o_ews_kpi_label">Quá hạn</span>
                                    <span class="o_ews_kpi_value" t-esc="state.monthKpi.overdue"/>
                                </div>
                                <div class="o_ews_kpi_card o_ews_kpi_hours">
                                    <span class="o_ews_kpi_label">Tổng TG (giờ)</span>
                                    <span class="o_ews_kpi_value" t-esc="state.monthKpi.duration_hours || 0"/>
                                </div>
                                <div class="o_ews_kpi_card o_ews_kpi_pct">
                                    <span class="o_ews_kpi_label">Tổng % Hoàn thành CV (AVERAGE hạng mục)</span>
                                    <span class="o_ews_kpi_value"
                                          t-esc="formatMonthAvgCompletion() + '%'"/>
                                </div>
                            </div>

                            <div class="o_ews_excel_wrap">
                                <table class="o_ews_excel_table">
                                    <thead>
                                        <tr>
                                            <th class="o_ews_col_stt">STT</th>
                                            <th>Tên công việc</th>
                                            <th>Ngày giao việc</th>
                                            <th>Hạn hoàn thành</th>
                                            <th>Mức ưu tiên</th>
                                            <th>Trạng thái</th>
                                            <th>Phút</th>
                                            <th>Giờ</th>
                                            <th>% Hoàn thành CV</th>
                                            <th>Ghi chú</th>
                                            <th>Quá hạn</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-if="!state.monthRows.length">
                                            <tr>
                                                <td colspan="11" class="text-center text-muted py-4">
                                                    Không có công việc trong tháng này.
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-foreach="monthGroups" t-as="group" t-key="group.key">
                                            <tr class="o_ews_excel_group">
                                                <td colspan="11">
                                                    <span class="o_ews_excel_group_name">
                                                        <i class="fa fa-folder-open-o"/>
                                                        <t t-esc="group.label"/>
                                                    </span>
                                                    <span class="o_ews_excel_group_meta">
                                                        <t t-esc="group.count"/> việc ·
                                                        <t t-esc="group.duration_hours_display"/> giờ ·
                                                        % Hoàn thành CV TB hạng mục (AVERAGE):
                                                        <strong t-esc="formatGroupAvgCompletion(group)"/>%
                                                    </span>
                                                </td>
                                            </tr>
                                            <t t-foreach="group.rows" t-as="row" t-key="row.id">
                                                <tr t-att-class="monthRowClass(row)">
                                                    <td class="o_ews_col_stt" t-esc="row.stt"/>
                                                    <td t-esc="row.name"/>
                                                    <td t-esc="row.assign_date_display || '—'"/>
                                                    <td t-esc="row.deadline_display"/>
                                                    <td>
                                                        <span t-att-class="'o_ews_badge ' + priorityClass(row.priority)"
                                                              t-esc="row.priority_label"/>
                                                    </td>
                                                    <td>
                                                        <span t-att-class="'o_ews_state_badge ' + stateBadgeClass(row.state)"
                                                              t-esc="row.state_label"/>
                                                    </td>
                                                    <td t-esc="row.duration_minutes || 0"/>
                                                    <td t-esc="row.duration_hours_display || formatHours(row.duration_minutes)"/>
                                                    <td t-esc="(row.completion_percent || 0) + '%'"/>
                                                    <td t-esc="row.note"/>
                                                    <td>
                                                        <t t-if="row.overdue_days">
                                                            <span class="o_ews_overdue_flag" t-att-title="row.overdue_label">
                                                                <i class="fa fa-exclamation-triangle"/>
                                                                <t t-esc="row.overdue_label"/>
                                                            </span>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </t>
                                        <t t-if="monthGroups.length">
                                            <tr class="o_ews_excel_total_avg">
                                                <td colspan="11">
                                                    Tổng % hoàn thành công việc trong tháng
                                                    (AVERAGE các hạng mục):
                                                    <strong t-esc="formatMonthAvgCompletion()"/>%
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </section>
                </t>
            </div>
        </div>
    </t>
</templates>
