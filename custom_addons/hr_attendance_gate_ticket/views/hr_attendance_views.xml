<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_attendance_view_form_inherit" model="ir.ui.view">
        <field name="name">hr.attendance.view.form.inherit.gate.ticket</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="attendance_type" invisible="1"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,confirm,second_approve,third_approve,validate"
                       invisible="attendance_type != 'gateway'"/>
                <button name="action_submit" string="Submit" type="object"
                        class="oe_highlight"
                        invisible="state != 'draft' or attendance_type != 'gateway'"
                        groups="base.group_user"/>
                <button name="action_first_approve" string="First Approve" type="object"
                        class="oe_highlight"
                        invisible="state not in ['confirm', 'refuse'] or attendance_type != 'gateway'"
                        groups="hr_attendance.group_hr_attendance_officer"/>
                <button name="action_second_approve" string="Second Approve" type="object"
                        class="oe_highlight"
                        invisible="state != 'second_approve' or attendance_type != 'gateway'"
                        groups="hr_attendance.group_hr_attendance_officer"/>
                <button name="action_third_approve" string="Third Approve" type="object"
                        class="oe_highlight"
                        invisible="state != 'third_approve' or attendance_type != 'gateway'"
                        groups="hr_attendance.group_hr_attendance_officer"/>
                <button name="action_refuse" string="Refuse" type="object"
                        invisible="state not in ['confirm', 'second_approve', 'third_approve', 'validate'] or attendance_type != 'gateway'"
                        groups="hr_attendance.group_hr_attendance_officer"/>
                <button name="action_draft" string="Reset to Draft" type="object"
                        invisible="state == 'draft' or attendance_type != 'gateway'"
                        groups="hr_attendance.group_hr_attendance_manager"/>
            </xpath>

            <field name="check_in" position="after">
                <field name="attendance_type"/>
                <field name="gate_ticket" invisible="attendance_type != 'gateway'"/>
                <field name="gate_items" invisible="attendance_type != 'gateway'"/>
                <field name="checkout_time" invisible="attendance_type != 'gateway'"/>
                <field name="approver_id" invisible="attendance_type != 'gateway'"/>
                <field name="second_approver_id" invisible="attendance_type != 'gateway'"/>
                <field name="third_approver_id" invisible="attendance_type != 'gateway'"/>
            </field>

            <field name="check_out" position="attributes">
                <attribute name="invisible">attendance_type == 'gateway'</attribute>
            </field>
            <field name="worked_hours" position="attributes">
                <attribute name="invisible">attendance_type == 'gateway'</attribute>
            </field>
            <xpath expr="//field[@name='overtime_hours']" position="attributes">
                <attribute name="invisible">attendance_type == 'gateway'</attribute>
            </xpath>
        </field>
    </record>


    <record id="hr_attendance_view_filter_inherit" model="ir.ui.view">
        <field name="name">hr.attendance.view.filter.inherit.gate.ticket</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_filter"/>
        <field name="arch" type="xml">
            <field name="employee_id" position="after">
                <field name="attendance_type"/>
                <field name="gate_ticket"/>
            </field>
            <filter name="employee" position="after">
                <filter string="Type" name="groupby_type" context="{'group_by': 'attendance_type'}"/>
            </filter>
        </field>
    </record>

    <record id="hr_attendance_management_tree_view" model="ir.ui.view">
        <field name="name">hr.attendance.management.tree</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance Management" decoration-info="state == 'draft'"
                  decoration-warning="state == 'confirm'" decoration-muted="state in ['second_approve', 'third_approve']"
                  decoration-success="state == 'validate'" decoration-danger="state == 'refuse'">
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="attendance_type"/>
                <field name="gate_ticket"/>
                <field name="gate_items" optional="hide"/>
                <field name="checkout_time" optional="hide"/>
                <field name="approver_id" optional="show"/>
                <field name="second_approver_id" optional="show"/>
                <field name="third_approver_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirm'"
                       decoration-muted="state in ['second_approve', 'third_approve']"
                       decoration-success="state == 'validate'"
                       decoration-danger="state == 'refuse'"/>
                <button name="action_first_approve" type="object" string="First Approve"
                        class="btn-primary"
                        icon="fa-check"
                        invisible="state not in ['confirm', 'refuse']"
                        groups="hr_attendance.group_hr_attendance_officer"/>
                <button name="action_second_approve" type="object" string="Second Approve"
                        class="btn-info"
                        icon="fa-check-double"
                        invisible="state != 'second_approve'"
                        groups="hr_attendance.group_hr_attendance_officer"/>
                <button name="action_third_approve" type="object" string="Third Approve"
                        class="btn-success"
                        icon="fa-check-circle"
                        invisible="state != 'third_approve'"
                        groups="hr_attendance.group_hr_attendance_officer"/>
                <button name="action_refuse" type="object" string="Refuse"
                        class="btn-danger"
                        icon="fa-times"
                        invisible="state not in ['confirm', 'second_approve', 'third_approve', 'validate']"
                        groups="hr_attendance.group_hr_attendance_officer"/>
            </list>
        </field>
    </record>

    <record id="hr_attendance_gateway_action" model="ir.actions.act_window">
        <field name="name">Gateway</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="hr_attendance_management_tree_view"/>
        <field name="domain">[('attendance_type', '=', 'gateway')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No gateway tickets to approve
            </p>
            <p>
                This view allows you to manage and approve gateway tickets.
            </p>
        </field>
    </record>

    <menuitem id="menu_hr_attendance_gateway"
              name="Gateway"
              parent="hr_attendance.menu_hr_attendance_root"
              action="hr_attendance_gateway_action"
              sequence="7"
              groups="hr_attendance.group_hr_attendance_officer"/>
</odoo>
