msgstr "Nội dung công việc"

#. module: time_off_extra_approval
msgid "Handover recipient"
msgstr "Người nhận bàn giao"

#. module: time_off_extra_approval
msgid "No."
msgstr "STT"

#. module: time_off_extra_approval
msgid "Replace"
msgstr "Cần thay"

#. module: time_off_extra_approval
msgid "New recipient"
msgstr "Người nhận"

#. module: time_off_extra_approval
msgid "Time Off"
msgstr "Nghỉ phép"

#. module: time_off_extra_approval
msgid "Time Off Request"
msgstr "Đơn nghỉ"

#. module: time_off_extra_approval
msgid "Work handover acceptance"
msgstr "Xác nhận bàn giao công việc"

#. module: time_off_extra_approval
msgid "Handover recipient replacement line"
msgstr "Dòng chọn lại người nhận bàn giao"

#. module: time_off_extra_approval
msgid ""
"Selected handover recipients are on leave during this period: %(names)s. "
"Please choose other colleagues."
msgstr ""
"Người nhận bàn giao đã chọn đang nghỉ phép trong giai đoạn này: %(names)s. "
"Vui lòng chọn đồng nghiệp khác."

#. module: time_off_extra_approval
msgid "Open this request and assign another colleague in Work Handover To."
msgstr "Mở yêu cầu này và chỉ định đồng nghiệp khác trong mục Người nhận bàn giao công việc."

#. module: time_off_extra_approval
msgid ""
"Open this request, then remove the declined recipient or select another "
"colleague in Work Handover To."
msgstr ""
"Mở yêu cầu này, sau đó xóa người đã từ chối hoặc chọn đồng nghiệp khác trong "
"mục Người nhận bàn giao công việc."

#. module: time_off_extra_approval
msgid "New handover recipients must be unique across lines."
msgstr "Người nhận bàn giao mới không được trùng nhau giữa các dòng."

#. module: time_off_extra_approval
msgid "Auto-escalate after (hours)"
msgstr "Tự động chuyển cấp sau (giờ)"

#. module: time_off_extra_approval
msgid "Special employees"
msgstr "Nhân viên đặc biệt"

#. module: time_off_extra_approval
msgid "Special employee list"
msgstr "Danh sách nhân viên đặc biệt"

#. module: time_off_extra_approval
msgid "Employee"
msgstr "Nhân viên"

#. module: time_off_extra_approval
msgid "Sequential director approval"
msgstr "Duyệt theo thứ tự Giám đốc"

#. module: time_off_extra_approval
msgid "Director order"
msgstr "Thứ tự Giám đốc"

#. module: time_off_extra_approval
msgid "Director"
msgstr "Giám đốc"

#. module: time_off_extra_approval
msgid "Org chart + sequential mode (outside the special employee list): the final Director step is assigned to the Department Manager (Manager field on the employee's department), not necessarily the Director in the management chain."
msgstr "Sơ đồ + tuần tự (ngoài danh sách nhân viên đặc biệt): bước Giám đốc cuối giao cho Quản lý phòng ban (trường trên Phòng ban của nhân viên), không bắt buộc theo Giám đốc trên chuỗi quản lý."

#. module: time_off_extra_approval
msgid "For employees listed below, approval stays sequential by org chart until the Director level. If \"Sequential director approval\" is disabled, all Directors are notified and can approve in parallel. If enabled, Directors approve in sequence according to the second table."
msgstr "Nhân viên trong bảng dưới: ở chế độ duyệt tuần tự theo sơ đồ cho tới khi tới cấp Giám đốc. Nếu không tích \"Duyệt theo thứ tự Giám đốc\", tất cả Giám đốc cùng nhận thông báo và có thể duyệt song song. Nếu tích, thứ tự duyệt giữa các Giám đốc theo bảng thứ hai."

#. module: time_off_extra_approval
msgid "Cancel"
msgstr "Hủy"

#. module: time_off_extra_approval
msgid "Time Off Request"
msgstr "Đơn nghỉ phép"

#. module: time_off_extra_approval
msgid "Accept work handover"
msgstr "Chấp nhận bàn giao công việc"

#. module: time_off_extra_approval
msgid "Refuse work handover"
msgstr "Từ chối bàn giao công việc"

#. module: time_off_extra_approval
msgid "Work Handover To"
msgstr "Người nhận bàn giao công việc"

#. module: time_off_extra_approval
msgid "Yes"
msgstr "Có"

#. module: time_off_extra_approval
msgid "No"
msgstr "Không"

#. module: time_off_extra_approval
msgid "Apply"
msgstr "Áp dụng"

#. module: time_off_extra_approval
msgid "Cancel"
msgstr "Hủy"

#. module: time_off_extra_approval
msgid "Work handover refusal details"
msgstr "Chi tiết từ chối bàn giao công việc"

#. module: time_off_extra_approval
msgid "HR responsibles workflow"
msgstr "Quy trình phê duyệt của nhân sự phụ trách"

#. module: time_off_extra_approval
msgid "Work handover escalation"
msgstr "Chuyển cấp bàn giao công việc"

#. module: time_off_extra_approval
msgid "Handover: escalate after (hours)"
msgstr "Bàn giao: chuyển cấp sau (giờ)"

#. module: time_off_extra_approval
msgid "Handover: escalation progression"
msgstr "Cách chuyển tiếp bàn giao"

#. module: time_off_extra_approval
msgid "Sequential"
msgstr "Tuần tự"

#. module: time_off_extra_approval
msgid "Direct"
msgstr "Trực tiếp"

#. module: time_off_extra_approval
msgid "Handover: max escalation job title"
msgstr "Bàn giao: chức danh chuyển cấp tối đa"

#. module: time_off_extra_approval
msgid "Handover: auto-cancel at max escalation level"
msgstr "Bàn giao: tự động hủy ở cấp chuyển cấp tối đa"

#. module: time_off_extra_approval
msgid "Approval escalation"
msgstr "Chuyển cấp duyệt"

#. module: time_off_extra_approval
msgid "Approval: escalate after (hours)"
msgstr "Duyệt: chuyển cấp sau (giờ)"

#. module: time_off_extra_approval
msgid "Approval: escalation progression"
msgstr "Cách chuyển tiếp duyệt"

#. module: time_off_extra_approval
msgid "Approval: max escalation job title"
msgstr "Duyệt: chức danh chuyển cấp tối đa"

#. module: time_off_extra_approval
msgid "Approval: auto-cancel at max escalation level"
msgstr "Duyệt: tự động hủy ở cấp chuyển cấp tối đa"

#. module: time_off_extra_approval
msgid "Approval: escalate to next level after (hours)"
msgstr "Duyệt: chuyển cấp tiếp theo sau (giờ)"

#. module: time_off_extra_approval
msgid "Approval: cancel after timeout at max level (hours)"
msgstr "Duyệt: hủy sau thời gian chờ ở cấp tối đa (giờ)"

#. module: time_off_extra_approval
msgid "If nobody approves within this period, escalation starts."
msgstr ""
"Nếu trong khoảng thời gian này không có ai duyệt, hệ thống bắt đầu chuyển "
"cấp."

#. module: time_off_extra_approval
msgid "Maximum job title level used for approval escalation."
msgstr "Chức danh cao nhất mà quy trình chuyển cấp duyệt được phép leo tới."

#. module: time_off_extra_approval
msgid ""
"If enabled, request auto-cancels when it reaches max escalation level and "
"still has no approver action in time."
msgstr ""
"Nếu bật, đơn sẽ tự động hủy khi đã chuyển cấp tới mức tối đa mà vẫn chưa có "
"người duyệt xử lý trong thời gian cho phép."

#. module: time_off_extra_approval
msgid "Handover: escalate to next level after (hours)"
msgstr "Bàn giao: chuyển cấp tiếp theo sau (giờ)"

#. module: time_off_extra_approval
msgid "Handover: cancel after timeout at max level (hours)"
msgstr "Bàn giao: hủy sau thời gian chờ ở cấp tối đa (giờ)"

#. module: time_off_extra_approval
msgid "If nobody accepts handover within this period, escalation starts."
msgstr ""
"Nếu trong khoảng thời gian này không có ai chấp nhận bàn giao, hệ thống bắt "
"đầu chuyển cấp."

#. module: time_off_extra_approval
msgid ""
"Sequential: escalate one management level at a time on the org chart. Direct: "
"escalate immediately to the configured max job title on the requester's chain."
msgstr ""
"Tuần tự: chuyển cấp từng bậc quản lý trên sơ đồ tổ chức. Trực tiếp: chuyển "
"ngay tới chức danh chuyển cấp tối đa đã cấu hình trên chuỗi quản lý của "
"người xin nghỉ."

#. module: time_off_extra_approval
msgid "Maximum job title level used for handover escalation."
msgstr "Chức danh cao nhất mà quy trình chuyển cấp bàn giao được phép leo tới."

#. module: time_off_extra_approval
msgid ""
"If enabled, request auto-cancels when it reaches max escalation level and "
"still has no assignee in time."
msgstr ""
"Nếu bật, đơn sẽ tự động hủy khi đã chuyển cấp tới mức tối đa mà vẫn chưa có "
"người được chỉ định hoặc chấp nhận trong thời gian cho phép."

#. module: time_off_extra_approval
msgid "Used only when auto-cancel at max level is enabled."
msgstr "Chỉ dùng khi bật tự động hủy ở cấp chuyển cấp tối đa."

#. module: time_off_extra_approval
msgid ""
"When max level is Department Manager: wait this many hours after Department "
"Head before escalating further."
msgstr ""
"Khi cấp tối đa là Trưởng phòng: chờ thêm số giờ này sau Trưởng bộ phận rồi "
"mới chuyển cấp tiếp."

#. module: time_off_extra_approval
msgid "Multi-step approval (6 steps)"
msgstr "Phê duyệt nhiều bước (6 bước)"

#. module: time_off_extra_approval
msgid "Approvers (HR employees, one per step)"
msgstr "Người phê duyệt (nhân sự, mỗi bước một người)"

#. module: time_off_extra_approval
msgid "Approve"
msgstr "Phê duyệt"

#. module: time_off_extra_approval
msgid "Refuse"
msgstr "Từ chối"

#. module: time_off_extra_approval
msgid "Validate Step"
msgstr "Duyệt bước"

#. module: time_off_extra_approval
msgid "Refuse Step"
msgstr "Từ chối bước"

#. module: time_off_extra_approval
msgid "Awaiting"
msgstr "Đang chờ"

#. module: time_off_extra_approval
msgid "Status"
msgstr "Trạng thái"

#. module: time_off_extra_approval
msgid "Submit Refusal"
msgstr "Gửi từ chối"

#. module: time_off_extra_approval
msgid "Refuse Work Handover"
msgstr "Từ chối bàn giao công việc"

#. module: time_off_extra_approval
#. odoo-javascript
msgid "Emergency leave confirmation"
msgstr "Xác nhận nghỉ phép khẩn cấp"
