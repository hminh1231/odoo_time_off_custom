<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_leave_handover_refuse_wizard_form" model="ir.ui.view">
        <field name="name">hr.leave.handover.refuse.wizard.form</field>
        <field name="model">hr.leave.handover.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Refuse Work Handover" create="false" edit="false">
                <sheet>
                    <group>
                        <field name="leave_id" readonly="1"/>
                        <field name="reason" placeholder="Explain why you cannot take this handover..." required="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_submit" type="object" string="Submit Refusal" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
