<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      List view row buttons used can_approve / can_refuse (cleared for custom validation types).
      Use Responsible / multi-step actions like Kanban.
    -->
    <record id="hr_leave_view_tree_extra_approval" model="ir.ui.view">
        <field name="name">hr.leave.list.extra.approval</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="before">
                <field name="validation_type" column_invisible="1"/>
                <field name="can_responsible_approve" column_invisible="1"/>
                <field name="can_multi_step_approve" column_invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="approval_current_step_label" optional="show" string="Awaiting"/>
            </xpath>
            <xpath expr="//field[@name='message_needaction']/following-sibling::button[@icon='fa-thumbs-up']" position="replace">
                <button string="Approve" name="action_responsible_approve" type="object"
                    icon="fa-thumbs-up"
                    invisible="validation_type != 'employee_hr_responsibles' or not can_responsible_approve"/>
                <button string="Approve" name="action_multi_step_approve" type="object"
                    icon="fa-thumbs-up"
                    invisible="validation_type != 'multi_step_6' or not can_multi_step_approve"/>
                <button string="Approve" name="action_approve" type="object"
                    icon="fa-thumbs-up"
                    invisible="validation_type in ('employee_hr_responsibles', 'multi_step_6') or not can_approve"/>
            </xpath>
            <xpath expr="//field[@name='message_needaction']/following-sibling::button[@icon='fa-check']" position="attributes">
                <attribute name="invisible">validation_type in ('employee_hr_responsibles', 'multi_step_6') or not can_validate or can_approve</attribute>
            </xpath>
            <xpath expr="//field[@name='message_needaction']/following-sibling::button[@icon='fa-times']" position="replace">
                <button string="Refuse" name="action_responsible_refuse" type="object"
                    icon="fa-times"
                    invisible="validation_type != 'employee_hr_responsibles' or not can_responsible_approve"/>
                <button string="Refuse" name="action_multi_step_refuse" type="object"
                    icon="fa-times"
                    invisible="validation_type != 'multi_step_6' or not can_multi_step_approve"/>
                <button string="Refuse" name="action_refuse" type="object"
                    icon="fa-times"
                    invisible="validation_type in ('employee_hr_responsibles', 'multi_step_6') or not can_refuse"/>
            </xpath>
        </field>
    </record>
</odoo>
