<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_view_form_handover_emergency_banner" model="ir.ui.view">
        <field name="name">hr.leave.form.handover.emergency</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="time_off_work_handover.hr_leave_view_form_handover_recipients"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='can_skip_work_handover']" position="before">
                <field name="is_emergency_leave" invisible="1"/>
                <div class="alert alert-warning" role="status" invisible="not is_emergency_leave">
                    This request is recorded as emergency leave (insufficient advance notice).
                </div>
            </xpath>
        </field>
    </record>

    <record id="hr_leave_view_form_dashboard_handover_emergency" model="ir.ui.view">
        <field name="name">hr.leave.form.dashboard.handover.emergency</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="time_off_work_handover.hr_leave_view_form_dashboard_handover_actions"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='can_respond_handover']" position="before">
                <field name="is_emergency_leave" invisible="1"/>
                <div class="alert alert-warning mb-2" role="status" invisible="not is_emergency_leave">
                    This request is recorded as emergency leave (insufficient advance notice).
                </div>
            </xpath>
        </field>
    </record>
</odoo>
