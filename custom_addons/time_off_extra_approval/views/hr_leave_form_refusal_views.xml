<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_view_form_refusal_details" model="ir.ui.view">
        <field name="name">hr.leave.form.refusal.details</field>
        <field name="model">hr.leave</field>
        <field name="priority">91</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('col_right')]" position="inside">
                <div
                    class="o_hr_leave_refusal_details mt-3"
                    invisible="state != 'refuse'"
                >
                    <table class="table table-sm table-bordered mb-0">
                        <tbody>
                            <tr>
                                <th class="text-nowrap align-top w-25 bg-100">Người từ chối</th>
                                <td>
                                    <field
                                        name="last_refuser_id"
                                        readonly="1"
                                        nolabel="1"
                                        widget="many2one_avatar_user"
                                    />
                                </td>
                            </tr>
                            <tr>
                                <th class="text-nowrap align-top w-25 bg-100">Lý do từ chối</th>
                                <td>
                                    <field
                                        name="last_refusal_reason"
                                        readonly="1"
                                        nolabel="1"
                                    />
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
