<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_view_form_mobile_date_layout" model="ir.ui.view">
        <field name="name">hr.leave.form.mobile.date.layout</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='full_date']/div[last()]" position="replace">
                <div class="o_hr_leave_duration_display">
                    <field name="request_calendar_days_display" readonly="1" class="w-auto"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
