<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate off so ir.rule domain fixes apply on -u (extra_approver M2M needs [user.id]) -->
    <data>
        <record id="hr_leave_rule_extra_approver" model="ir.rule">
            <field name="name">Time Off: Extra Approvers access</field>
            <field name="model_id" ref="model_hr_leave"/>
            <field name="domain_force">
                [
                    ('employee_id', '!=', False),
                    ('state', 'in', ['confirm', 'validate1', 'validate', 'refuse']),
                    ('extra_approver_user_ids', 'in', [user.id]),
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="hr_leave_allocation_rule_extra_approver" model="ir.rule">
            <field name="name">Time Off Allocation: Extra Approvers access</field>
            <field name="model_id" ref="model_hr_leave_allocation"/>
            <field name="domain_force">
                [
                    ('employee_id', '!=', False),
                    ('state', 'in', ['confirm', 'validate', 'refuse']),
                    ('extra_approver_user_ids', 'in', [user.id]),
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="hr_leave_allocation_rule_manager_type" model="ir.rule">
            <field name="name">Time Off Allocation: Manager approval access</field>
            <field name="model_id" ref="model_hr_leave_allocation"/>
            <field name="domain_force">
                [
                    ('employee_id', '!=', False),
                    ('state', 'in', ['confirm', 'validate', 'refuse']),
                    ('employee_id.leave_manager_id', '=', user.id),
                    ('holiday_status_id.allocation_validation_type', '=', 'manager'),
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>

