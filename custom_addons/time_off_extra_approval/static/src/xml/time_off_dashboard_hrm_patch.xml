<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="hr_holidays.TimeOffDashboard" t-inherit-mode="extension">
        <xpath expr="//div[strong[@class='o_timeoff_name']]" position="inside">
            <div class="d-flex gap-3 mt-1 text-muted small">
                <span>Đã sử dụng: <strong t-esc="state.daSuDung"/></span>
                <span>Còn lại: <strong t-esc="state.conLai"/></span>
            </div>
        </xpath>
    </t>
</templates>
