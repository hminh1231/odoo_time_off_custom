<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
    When LUG Permission is active, cap hr.leave list/overview reads to the same
    visibility_policy as employee profiles (VP region for anh.trinh, etc.).
    Approval-specific rules may still expose individual requests.
    -->
    <record id="hr_leave_lug_scope_rule" model="ir.rule">
        <field name="name">Time Off: LUG data scope read cap</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave"/>
        <field name="groups" eval="[]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
