<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_lug_app_list" model="ir.ui.view">
        <field name="name">lug.app.list</field>
        <field name="model">lug.app</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="module_name"/>
                <field name="menu_xmlid"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lug_app_form" model="ir.ui.view">
        <field name="name">lug.app.form</field>
        <field name="model">lug.app</field>
        <field name="arch" type="xml">
            <form string="Application">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Tên ứng dụng"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="module_name"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="menu_xmlid"/>
                            <field name="extra_menu_xmlids"/>
                        </group>
                    </group>
                    <group string="Mô tả">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lug_app" model="ir.actions.act_window">
        <field name="name">Ứng dụng</field>
        <field name="res_model">lug.app</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
