<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_lug_group_permission_list" model="ir.ui.view">
        <field name="name">lug.group.permission.list</field>
        <field name="model">lug.group.permission</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="app_id" options="{'no_create': True}"/>
                <field name="perm_view"/>
                <field name="perm_create"/>
                <field name="perm_edit"/>
                <field name="perm_delete"/>
                <field name="perm_approve"/>
                <field name="perm_export"/>
                <field name="perm_import"/>
                <field name="perm_print"/>
            </list>
        </field>
    </record>

    <record id="view_lug_group_list" model="ir.ui.view">
        <field name="name">lug.group.list</field>
        <field name="model">lug.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="user_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lug_group_form" model="ir.ui.view">
        <field name="name">lug.group.form</field>
        <field name="model">lug.group</field>
        <field name="arch" type="xml">
            <form string="Nhóm quyền">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_users" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="user_count" widget="statinfo" string="Users"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Tên nhóm quyền"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Phân quyền ứng dụng" name="permissions">
                            <field name="permission_line_ids" nolabel="1"/>
                        </page>
                        <page string="Người dùng" name="users">
                            <field name="user_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Mô tả" name="description">
                            <field name="description" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lug_group" model="ir.actions.act_window">
        <field name="name">Nhóm quyền</field>
        <field name="res_model">lug.group</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
