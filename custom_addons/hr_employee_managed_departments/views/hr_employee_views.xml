<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_managed_departments" model="ir.ui.view">
        <field name="name">hr.employee.form.managed.departments</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <field name="parent_id" position="after">
                <field name="is_department_director" invisible="1"/>
                <field name="managed_department_ids"
                       string="Managed Departments"
                       options="{'no_create': True}"
                       context="{'list_view_ref': 'hr_employee_managed_departments.view_hr_department_tree_managed_employee'}"
                       invisible="not is_department_director"/>
            </field>
        </field>
    </record>
</odoo>
