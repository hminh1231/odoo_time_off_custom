<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="user_menu_reset_password.UserMenuIdentity">
        <div>
            <div class="o_user_menu_identity d-flex align-items-center gap-3 px-3 py-3">
                <img class="o_user_menu_identity_avatar rounded-circle"
                     t-att-src="avatarSource"
                     alt="User"/>
                <div class="min-w-0">
                    <div class="o_user_menu_identity_name fw-semibold text-truncate">
                        <t t-esc="userName"/>
                    </div>
                    <div t-if="env.debug"
                         class="o_user_menu_identity_database font-monospace text-muted text-truncate">
                        <i class="fa fa-database me-1"/>
                        <t t-esc="dbName"/>
                    </div>
                </div>
            </div>
            <div role="separator" class="dropdown-divider mt-0"/>
        </div>
    </t>
</templates>
