<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
  <t t-name="mail_discuss_lark_ui.LarkMobileAppsBar">
    <t t-if="larkShowAppsBar">
      <div class="o-mail-LarkAppsBar-globalShell flex-shrink-0 w-100">
        <div
          t-if="larkAppsMenu.open"
          class="o-mail-LarkAllApps"
          role="dialog"
          aria-modal="true"
          t-att-aria-label="larkAllAppsTitle"
        >
          <div class="o-mail-LarkAllApps-backdrop" t-on-click="onLarkAllAppsClose"/>
          <div class="o-mail-LarkAllApps-panel d-flex flex-column">
            <header class="o-mail-LarkAllApps-header d-flex align-items-center flex-shrink-0 px-3 py-2 border-bottom">
              <h2 class="o-mail-LarkAllApps-title flex-grow-1 mb-0 fs-6 fw-bold" t-esc="larkAllAppsTitle"/>
              <button type="button" class="btn btn-link text-reset p-2" aria-label="Close" t-on-click="onLarkAllAppsClose">
                <i class="oi oi-close fs-4"/>
              </button>
            </header>
            <p class="o-mail-LarkAllApps-hint flex-shrink-0 px-3 py-1 mb-0 o-xsmaller text-muted" t-esc="larkCustomizeHint"/>
            <div class="o-mail-LarkAllApps-grid p-3" data-lark-allapps-grid="1">
              <button
                t-foreach="larkAllApps"
                t-as="app"
                t-key="app.id"
                type="button"
                class="o-mail-LarkAllApps-app o-mail-LarkDraggable btn border-0 bg-transparent p-2 d-flex flex-column align-items-center"
                t-att-class="{ 'o-active': larkCurrentAppId === app.id, 'o-in-bar': larkIsAppInBar(app.xmlid) }"
                t-att-title="app.name"
                t-att-data-lark-xmlid="app.xmlid"
                data-lark-drag-source="grid"
                t-on-pointerdown="onLarkAppDragPointerDown"
                t-on-pointerup="onLarkAppDragPointerUp"
                t-on-click="(ev) => this.onLarkAllAppClick(app, ev)"
              >
                <img
                  t-if="app.webIconData"
                  class="o-mail-LarkAllApps-appIcon rounded-2 object-fit-contain"
                  t-att-src="app.webIconData"
                  t-att-alt="app.name"
                />
                <span
                  t-else=""
                  class="o-mail-LarkAllApps-appIcon d-flex align-items-center justify-content-center rounded-2"
                  t-att-style="larkAppIconStyle(app)"
                >
                  <i t-if="app.webIcon?.iconClass" t-att-class="app.webIcon.iconClass"/>
                </span>
                <span class="o-mail-LarkAllApps-appLabel o-xsmaller text-center text-truncate w-100 mt-1" t-esc="app.name"/>
              </button>
            </div>
          </div>
        </div>
        <nav
          class="o-mail-LarkAppsBar o-mail-LarkAppsBar-global d-flex bg-view border-top w-100 py-1 px-2 gap-1"
          aria-label="App shortcuts"
        >
          <div
            t-foreach="larkBarSlots"
            t-as="slot"
            t-key="slot.index"
            class="o-mail-LarkAppsBar-slot d-flex flex-grow-1 flex-shrink-0 min-w-0"
            t-att-data-lark-bar-slot="slot.index"
            t-att-class="{
              'o-drop-target': larkDragState.active and larkDragState.hoverSlot === slot.index,
              'o-drop-empty': !slot.app,
            }"
          >
            <button
              t-if="slot.app"
              type="button"
              class="o-mail-LarkAppsBar-tab o-mail-LarkDraggable btn d-flex flex-column align-items-center flex-grow-1 w-100 p-1 bg-transparent border-0 position-relative"
              t-att-class="{ active: larkCurrentAppId === slot.app.id }"
              t-att-title="slot.app.name"
              t-att-aria-label="slot.app.name"
              t-att-data-lark-xmlid="slot.xmlid"
              t-att-data-lark-bar-slot="slot.index"
              data-lark-drag-source="bar"
              t-on-pointerdown="onLarkAppDragPointerDown"
              t-on-pointerup="onLarkAppDragPointerUp"
              t-on-click="(ev) => this.onLarkAppClick(slot.app, ev)"
            >
              <img
                t-if="slot.app.webIconData"
                class="o-mail-LarkAppsBar-icon rounded-1 object-fit-contain"
                t-att-src="slot.app.webIconData"
                t-att-alt="slot.app.name"
              />
              <span
                t-else=""
                class="o-mail-LarkAppsBar-icon d-flex align-items-center justify-content-center rounded-1"
                t-att-style="larkAppIconStyle(slot.app)"
              >
                <i t-if="slot.app.webIcon?.iconClass" t-att-class="slot.app.webIcon.iconClass"/>
              </span>
              <span class="o-mail-LarkAppsBar-label o-xsmaller text-truncate w-100 text-center" t-esc="slot.app.name"/>
            </button>
            <div
              t-else=""
              class="o-mail-LarkAppsBar-slotEmpty flex-grow-1 w-100"
              t-att-title="larkCustomizeHint"
            />
          </div>
          <button
            type="button"
            class="o-mail-LarkAppsBar-tab o-mail-LarkAppsBar-more btn d-flex flex-column align-items-center flex-grow-1 flex-shrink-0 p-1 bg-transparent border-0"
            t-att-class="{ active: larkAppsMenu.open }"
            t-att-title="larkSeeMoreLabel"
            t-att-aria-label="larkSeeMoreLabel"
            t-att-aria-expanded="larkAppsMenu.open"
            t-on-click="onLarkMoreAppsClick"
          >
            <span class="o-mail-LarkAppsBar-moreIcon rounded-1" aria-hidden="true">
              <span/><span/><span/><span/>
            </span>
            <span class="o-mail-LarkAppsBar-label o-xsmaller text-truncate w-100 text-center" t-esc="larkSeeMoreLabel"/>
          </button>
        </nav>
      </div>
    </t>
  </t>

  <t t-inherit="mail.MessagingMenu.content" t-inherit-mode="extension">
    <xpath expr="//*[@name='before-content']" position="before">
      <header
        t-if="ui.isSmall and env.inDiscussApp"
        class="o-mail-LarkHeader flex-shrink-0 w-100 bg-view px-3 pb-1"
      >
        <div class="o-mail-LarkHeader-toolbar d-flex align-items-center justify-content-end gap-1 pt-1">
          <button
            type="button"
            class="o-mail-LarkHeader-iconBtn btn btn-link text-reset p-2"
            title="Search"
            aria-label="Search"
            t-on-click="onLarkSearchClick"
          >
            <i class="fa fa-search"/>
          </button>
          <button
            type="button"
            class="o-mail-LarkHeader-iconBtn btn btn-link text-reset p-2"
            title="New"
            aria-label="New"
            t-on-click="onLarkComposeClick"
          >
            <i class="fa fa-plus-circle"/>
          </button>
        </div>
      </header>
    </xpath>
  </t>
</templates>
