<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="hr_leave_report_calendar_view_status_colors" model="ir.ui.view">
        <field name="name">hr.leave.report.calendar.view.status.colors</field>
        <field name="model">hr.leave.report.calendar</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_report_calendar_view"/>
        <field name="arch" type="xml">
            <field name="is_hatched" position="after">
                <field name="is_striked" invisible="1"/>
            </field>
        </field>
    </record>

    <record id="hr_leave_report_calendar_year_view_status_colors" model="ir.ui.view">
        <field name="name">hr.leave.report.calendar.year.view.status.colors</field>
        <field name="model">hr.leave.report.calendar</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_report_calendar_year_view"/>
        <field name="arch" type="xml">
            <field name="is_hatched" position="after">
                <field name="is_striked" invisible="1"/>
            </field>
        </field>
    </record>
</odoo>
