<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        ir.model.access CSV uses xmlid model_* which may not exist yet when the CSV is loaded.
        Here we bind by technical model name via search (ir.model row exists after init_models).
    -->
    <record id="access_hr_leave_handover_replacement_draft_user" model="ir.model.access">
        <field name="name">time_off_work_handover.handover.replacement.draft.user</field>
        <field name="model_id" model="ir.model" search="[('model', '=', 'hr.leave.handover.replacement.draft')]"/>
        <field name="group_id" ref="base.group_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
    <record id="access_hr_leave_handover_replacement_draft_officer" model="ir.model.access">
        <field name="name">time_off_work_handover.handover.replacement.draft.officer</field>
        <field name="model_id" model="ir.model" search="[('model', '=', 'hr.leave.handover.replacement.draft')]"/>
        <field name="group_id" ref="hr_holidays.group_hr_holidays_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
    <record id="access_hr_leave_handover_replacement_draft_manager" model="ir.model.access">
        <field name="name">time_off_work_handover.handover.replacement.draft.manager</field>
        <field name="model_id" model="ir.model" search="[('model', '=', 'hr.leave.handover.replacement.draft')]"/>
        <field name="group_id" ref="hr_holidays.group_hr_holidays_manager"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
</odoo>
