<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hr_leave_rule_handover_recipient_read" model="ir.rule">
            <field name="name">Time Off: Work handover recipient read</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">[('handover_employee_ids.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="hr_leave_handover_acceptance_requester_rule" model="ir.rule">
            <field name="name">Work handover acceptance: requester on own leave</field>
            <field name="model_id" ref="model_hr_leave_handover_acceptance"/>
            <field name="domain_force">[('leave_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="hr_leave_handover_acceptance_recipient_rule" model="ir.rule">
            <field name="name">Work handover acceptance: assigned recipient</field>
            <field name="model_id" ref="model_hr_leave_handover_acceptance"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="hr_leave_handover_acceptance_approver_read_rule" model="ir.rule">
            <field name="name">Work handover acceptance: approver read-only</field>
            <field name="model_id" ref="model_hr_leave_handover_acceptance"/>
            <field name="domain_force">['|', '|', '|', ('leave_id.responsible_approval_line_ids.user_id', '=', user.id), ('leave_id.multi_approval_line_ids.approver_user_id', '=', user.id), ('leave_id.extra_approver_user_ids', 'in', [user.id]), ('leave_id.special_readonly_notifier_user_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
