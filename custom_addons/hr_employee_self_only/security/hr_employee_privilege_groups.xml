<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
    Third option on the same Employees privilege (with Officer / Administrator).
    Sequence must be *after* hr.group_hr_user (10): the user form widget drops "lower"
    options when HR Officer is implied from another privilege (e.g. Time Off Officer
    implies HR Officer). If "No" sorts before Officer, it is removed from the dropdown.
    -->
    <record id="group_hr_employees_no" model="res.groups">
        <field name="name">No</field>
        <field name="sequence">15</field>
        <field name="privilege_id" ref="hr.res_groups_privilege_employees"/>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        <field name="comment">User is not an HR officer; employee directory is limited by record rules (typically own profile only).</field>
    </record>
</odoo>
