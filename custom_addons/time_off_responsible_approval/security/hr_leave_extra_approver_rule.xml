<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- extra_approver_user_ids on hr.leave is defined here, so the ir.rule lives here too -->
    <data>
        <record id="hr_leave_rule_extra_approver" model="ir.rule">
            <field name="name">Time Off: Extra Approvers access</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">
                [
                    '|',
                    ('responsible_approval_line_ids.user_id', '=', user.id),
                    '&amp;',
                    ('employee_id', '!=', False),
                    '|',
                    ('extra_approver_user_ids', 'in', [user.id]),
                    ('approval_actionable_user_ids', 'in', [user.id]),
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="hr_leave_rule_special_readonly_notifier_read" model="ir.rule">
            <field name="name">Time Off: Special read-only notifier access</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">
                [
                    ('employee_id', '!=', False),
                    ('state', 'in', ['confirm', 'validate1', 'validate', 'refuse']),
                    ('special_readonly_notifier_user_ids', 'in', [user.id]),
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
