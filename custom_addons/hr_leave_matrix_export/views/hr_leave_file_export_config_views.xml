<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_leave_file_export_config_list" model="ir.ui.view">
        <field name="name">hr.leave.file.export.config.list</field>
        <field name="model">hr.leave.file.export.config</field>
        <field name="arch" type="xml">
            <list string="Trích xuất file"
                  class="o_hr_leave_file_export_config_list"
                  js_class="hr_leave_file_export_config_list"
                  editable="bottom"
                  create="true"
                  delete="true">
                <field name="sequence" string="STT" readonly="1" width="48px"/>
                <field name="employee_hrm_id"
                       string="ID nhân viên"
                       required="1"
                       placeholder="ID HRM"
                       width="120px"/>
                <field name="employee_name" string="Tên nhân viên" readonly="1" width="160px"/>
                <field name="employee_id" column_invisible="True"/>
                <field name="export_leave_ch" string="Nghỉ phép CH" width="108px" widget="boolean"/>
                <field name="export_leave_vp" string="Nghỉ phép VP" width="108px" widget="boolean"/>
                <field name="export_import_capnhatcong_ch" string="Import công CH" width="152px" widget="boolean"/>
                <field name="export_import_capnhatcong_vp" string="Import công VP" width="152px" widget="boolean"/>
            </list>
        </field>
    </record>

    <record id="view_hr_leave_file_export_config_search" model="ir.ui.view">
        <field name="name">hr.leave.file.export.config.search</field>
        <field name="model">hr.leave.file.export.config</field>
        <field name="arch" type="xml">
            <search string="Trích xuất file">
                <field name="employee_hrm_id" string="ID nhân viên"/>
                <field name="employee_name" string="Tên nhân viên"/>
                <field name="employee_id"/>
                <separator/>
                <filter string="File nghỉ phép VP" name="leave_vp" domain="[('export_leave_vp', '=', True)]"/>
                <filter string="File nghỉ phép CH" name="leave_ch" domain="[('export_leave_ch', '=', True)]"/>
                <filter string="Import cập nhật công CH" name="import_capnhatcong_ch" domain="[('export_import_capnhatcong_ch', '=', True)]"/>
                <filter string="Import cập nhật công VP" name="import_capnhatcong_vp" domain="[('export_import_capnhatcong_vp', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_hr_leave_file_export_config" model="ir.actions.act_window">
        <field name="name">Trích xuất file</field>
        <field name="res_model">hr.leave.file.export.config</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_hr_leave_file_export_config_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Cấu hình quyền trích xuất file
            </p>
            <p>
                Nhập <strong>ID nhân viên (HRM)</strong> trên mỗi dòng và <strong>tích chọn</strong>
                các loại file mà nhân viên được phép trích xuất trong danh sách đơn nghỉ phép.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_hr_leave_file_export_configuration"
        name="Trích xuất file"
        parent="hr_holidays.menu_hr_holidays_configuration"
        action="action_hr_leave_file_export_config"
        groups="hr_holidays.group_hr_holidays_manager"
        sequence="7"/>

</odoo>
