<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payment_request_tree" model="ir.ui.view">
        <field name="name">payment.request.tree</field>
        <field name="model">payment.request</field>
        <field name="arch" type="xml">
            <tree string="Payment Requests" decoration-info="state=='draft'" decoration-warning="state in ('submitted','approved')" decoration-success="state=='paid'" decoration-danger="state=='rejected'">
                <field name="name"/>
                <field name="request_date"/>
                <field name="partner_id"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge" decoration-success="state=='paid'" decoration-info="state=='draft'" decoration-warning="state in ('submitted','approved')" decoration-danger="state=='rejected'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <record id="view_payment_request_form" model="ir.ui.view">
        <field name="name">payment.request.form</field>
        <field name="model">payment.request</field>
        <field name="arch" type="xml">
            <form string="Payment Request">
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_reject" type="object" string="Reject" invisible="state not in ('submitted', 'approved')"/>
                    <button name="action_paid" type="object" string="Mark Paid" class="btn-primary" invisible="state != 'approved'"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft" invisible="state not in ('rejected', 'paid')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="request_date"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="currency_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="payment_date" invisible="state != 'paid'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Purpose of payment, invoice refs, notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_payment_request_search" model="ir.ui.view">
        <field name="name">payment.request.search</field>
        <field name="model">payment.request</field>
        <field name="arch" type="xml">
            <search string="Payment Requests">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state','=','submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Paid" name="paid" domain="[('state','=','paid')]"/>
                <separator/>
                <filter string="My Requests" name="my_requests" domain="[('user_id','=',uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Requester" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_payment_request" model="ir.actions.act_window">
        <field name="name">Payment Requests</field>
        <field name="res_model">payment.request</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_my_requests': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a payment request
            </p>
            <p>
                Track internal requests for outgoing payments: submit, approve, and mark as paid when done.
            </p>
        </field>
    </record>

    <menuitem id="menu_payment_request_root"
              name="Payment Requests"
              sequence="45"/>

    <menuitem id="menu_payment_request_requests"
              name="Requests"
              parent="menu_payment_request_root"
              action="action_payment_request"
              sequence="10"/>
</odoo>
