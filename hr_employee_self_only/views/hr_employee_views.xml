<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_employee_form_personal_privacy" model="ir.ui.view">
        <field name="name">hr.employee.form.personal.privacy.employees.no</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="personal_tab_hidden_for_privacy" invisible="1"/>
                <field name="employee_form_force_readonly_ui" invisible="1"/>
            </xpath>
            <xpath expr="//page[@name='work_information']//field[@name='department_id']" position="replace">
                <field name="department_id" invisible="employee_form_force_readonly_ui" />
                <field name="department_id" invisible="not employee_form_force_readonly_ui" options="{'no_open': True}"/>
            </xpath>
            <xpath expr="//page[@name='work_information']//field[@name='job_id']" position="replace">
                <field name="job_id" string="Job Position" context="{'default_no_of_recruitment': 0, 'default_is_favorite': False}" placeholder="e.g. Sales Manager" invisible="employee_form_force_readonly_ui"/>
                <field name="job_id" string="Job Position" context="{'default_no_of_recruitment': 0, 'default_is_favorite': False}" placeholder="e.g. Sales Manager" invisible="not employee_form_force_readonly_ui" options="{'no_open': True}"/>
            </xpath>
            <xpath expr="//page[@name='work_information']//field[@name='parent_id']" position="replace">
                <field name="parent_id" widget="many2one_avatar_employee" invisible="employee_form_force_readonly_ui"/>
                <field name="parent_id" widget="many2one_avatar_employee" invisible="not employee_form_force_readonly_ui" options="{'no_open': True}"/>
            </xpath>
            <xpath expr="//page[@name='personal_information']" position="attributes">
                <attribute name="invisible">personal_tab_hidden_for_privacy</attribute>
            </xpath>
            <!-- Time Off Officer implies hr.group_hr_user, so the HR header still shows. Hide
                 Launch Plan for Employees=No when viewing another employee (same as Personal tab). -->
            <xpath expr="//header/button[@name='action_create_user']/following-sibling::button[1]" position="attributes">
                <attribute name="invisible">not active or not id or personal_tab_hidden_for_privacy</attribute>
            </xpath>
        </field>
    </record>
</odoo>
