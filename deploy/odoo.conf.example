[options]
db_host = db
db_port = 5432
db_user = odoo
db_password = change_me
db_name = odoo_db
list_db = False

; Built-in addons + mounted custom_addons repo
addons_path = /usr/lib/python3/dist-packages/odoo/addons,/mnt/extra-addons

http_port = 8069
proxy_mode = True

; Production-safe defaults to reduce cron lockups
workers = 2
max_cron_threads = 1
limit_time_real = 300
limit_time_cpu = 120
db_maxconn = 64
